^Ximport json
import time
import logging
import requests
from datetime import datetime, timezone
from kafka import KafkaProducer

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
logger = logging.getLogger(__name__)

# ── Config ────────────────────────────────────────────────────────────────────
KAFKA_BROKER    = "kafka:9092"
KAFKA_TOPIC     = "flights"
API_URL         = "https://api.airplanes.live/v2/point/51.5/0.0/250"
POLL_INTERVAL   = 10          # seconds
MAX_SEEN_POS    = 30.0        # skip aircraft with position older than 30s
# ─────────────────────────────────────────────────────────────────────────────


def fetch_flights() -> list[dict]:
    try:
        resp = requests.get(API_URL, timeout=10)
        resp.raise_for_status()
        data = resp.json()
    except requests.RequestException as e:
        logger.error(f"API request failed: {e}")
        return []

    aircraft = data.get("ac", [])
    logger.info(f"Fetched {len(aircraft)} aircraft from airplanes.live")

    records = []
    for ac in aircraft:
        # Must have a position
        if ac.get("lat") is None or ac.get("lon") is None:
            continue

        # Skip stale positions
        if ac.get("seen_pos", 9999) > MAX_SEEN_POS:
            continue

        # alt_baro can be the string "ground" — coerce to 0
        alt_baro = ac.get("alt_baro")
        if isinstance(alt_baro, str):
            alt_baro = 0

        alt_geom = ac.get("alt_geom")
        if isinstance(alt_geom, str):
            alt_geom = 0

        # vertical rate: field is geom_rate or baro_rate depending on aircraft
        vertical_rate = ac.get("geom_rate") or ac.get("baro_rate")

        records.append({
            "icao24":        ac.get("hex", "").lower().strip(),
            "callsign":      ac.get("flight", "").strip(),
            "registration":  ac.get("r", "").strip(),       # e.g. "G-FLYW"
            "aircraft_type": ac.get("t", "").strip(),       # e.g. "BE20"
            "description":   ac.get("desc", "").strip(),    # e.g. "BEECH 200 Super King Air"
            "latitude":      ac.get("lat"),
            "longitude":     ac.get("lon"),
            "altitude":      alt_baro,                      # feet, barometric
            "altitude_geom": alt_geom,                      # feet, geometric
            "velocity":      ac.get("gs"),                  # knots
            "heading":       ac.get("track"),               # degrees true
            "vertical_rate": vertical_rate,                 # ft/min
            "squawk":        ac.get("squawk"),
            "emergency":     ac.get("emergency", "none"),
            "category":      ac.get("category"),            # A1, A2 … A7
            "source":        ac.get("type", "unknown"),     # adsb_icao / mlat …
            "seen_pos":      ac.get("seen_pos"),            # seconds since last position
            "distance_km":   ac.get("dst"),                 # km from query point
            "timestamp":     datetime.now(timezone.utc).isoformat(),
        })

    return records


def main():
    producer = KafkaProducer(
        bootstrap_servers=KAFKA_BROKER,
        value_serializer=lambda v: json.dumps(v).encode("utf-8"),
        acks="all",
        retries=3,
    )
    logger.info(f"Kafka producer connected → topic: {KAFKA_TOPIC}")

    while True:
        records = fetch_flights()
        for record in records:
            producer.send(KAFKA_TOPIC, value=record)

        producer.flush()
        logger.info(f"Published {len(records)} records to Kafka")
        time.sleep(POLL_INTERVAL)


if __name__ == "__main__":
    main()
